# dns-edge 测试环境配置

dns-edge {
    # DNS 监听端口
    listen :5300

    # 工作进程数（SO_REUSEPORT，0 表示单 socket）
    workers 0

    # TCP 支持
    tcp true

    # API 端口
    api {
        listen :8080
    }

    # PostgreSQL 连接
    postgres {
        dsn postgres://postgres:3fcde0039bda0216c9f2fc18acb075aa@10.0.25.221:5432/postgres?sslmode=disable
    }

    # Nacos 配置中心（动态权重）
    nacos {
        addr 120.25.74.229:18848
        namespace scloud-prod
        group dns_edge
        username scloud-admin
        password <your-nacos-password>
    }

    # 增量同步配置
    sync {
        interval 30s
        prob 0.01
        ratelimit 100
    }
}
